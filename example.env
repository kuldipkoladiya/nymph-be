# Copy this file to .env and fill in your values

PORT=5000

# MongoDB connection string
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nymph

# JWT Secret — use a long random string
JWT_SECRET=your_super_secret_jwt_key_here

# One-time superadmin setup key
# This key is required to access /setup page and create the first superadmin account
# After setup is done, this key becomes useless (setup locks after first admin is created)
SETUP_SECRET_KEY=your_setup_secret_key_here
